generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         String    @default("AGENT") // ADMIN | AGENT
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  listings     Listing[]
  leads        Lead[]
  notes        LeadNote[]
  presentations Presentation[]
  supportCosts  AgentCost[]
  deals         Deal[]
  showings      Showing[]
  tasks         Task[]
}

model Listing {
  id           String         @id @default(cuid())
  webRef       String         @unique // Private Property web reference e.g. T4236137
  title        String
  address      String
  suburb       String
  price        Int
  status       String         @default("ACTIVE") // ACTIVE | UNDER_OFFER | SOLD | WITHDRAWN | EXPIRED
  propertyType String         @default("House")
  bedrooms     Int?
  url          String? // link to the live Private Property listing
  latitude     Float? // for the listings map
  longitude    Float?
  soldDate     DateTime? // set when status moves to SOLD; basis for sales reporting
  listedDate   DateTime       @default(now())
  commissionPct Float         @default(5.0) // gross commission % of sale price earned by the brokerage
  createdAt    DateTime       @default(now())
  agentId      String?
  agent        User?          @relation(fields: [agentId], references: [id])
  snapshots    ViewSnapshot[]
  leads        Lead[]
  deals        Deal[]
  showings     Showing[]
}

// One row per listing per report import: cumulative totals as reported by Property24.
model ViewSnapshot {
  id         String   @id @default(cuid())
  listingId  String
  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  capturedAt DateTime
  views      Int      @default(0) // cumulative page views
  alertsSent Int      @default(0)
  leadsCount Int      @default(0) // cumulative leads as counted by Property24
  createdAt  DateTime @default(now())

  @@unique([listingId, capturedAt])
}

model Lead {
  id         String     @id @default(cuid())
  name       String
  email      String?
  phone      String?
  message    String?
  source     String     @default("MANUAL") // EMAIL | WEBHOOK | IMPORT | MANUAL
  status     String     @default("NEW") // NEW | CONTACTED | VIEWING | OFFER | WON | LOST
  receivedAt DateTime   @default(now())
  createdAt  DateTime   @default(now())
  listingId  String?
  listing    Listing?   @relation(fields: [listingId], references: [id])
  agentId    String?
  agent      User?      @relation(fields: [agentId], references: [id])
  notes      LeadNote[]
  deals      Deal[]
  showings   Showing[]

  @@index([status])
  @@index([receivedAt])
}

// A transaction from accepted offer to registration — the paperless deal room.
model Deal {
  id            String         @id @default(cuid())
  listingId     String
  listing       Listing        @relation(fields: [listingId], references: [id])
  leadId        String?
  lead          Lead?          @relation(fields: [leadId], references: [id])
  agentId       String?
  agent         User?          @relation(fields: [agentId], references: [id])
  stage         String         @default("OFFER") // OFFER | OTP_SIGNED | BOND | INSPECTIONS | TRANSFER | REGISTERED
  salePrice     Int
  commissionPct Float          @default(5.0)
  agentSplitPct Float          @default(60.0) // agent's share of gross commission
  payoutStatus  String         @default("PENDING") // PENDING | PAID
  openedAt      DateTime       @default(now())
  closedAt      DateTime? // set when the deal registers
  documents     DealDocument[]
  tasks         Task[]
}

// Contract / disclosure / compliance paperwork tracked per deal.
model DealDocument {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  name      String
  kind      String // MANDATE | OTP | FICA | DISCLOSURE | COMPLIANCE | BOND
  status    String   @default("REQUIRED") // REQUIRED | UPLOADED | SENT | SIGNED
  updatedAt DateTime @updatedAt
}

// A viewing appointment or open house.
model Showing {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id])
  agentId   String
  agent     User     @relation(fields: [agentId], references: [id])
  startsAt  DateTime
  endsAt    DateTime
  kind      String   @default("PRIVATE") // PRIVATE | OPEN_HOUSE
  status    String   @default("REQUESTED") // REQUESTED | CONFIRMED | COMPLETED | CANCELLED
  feedback  String?

  @@index([startsAt])
}

// Shared team to-dos, optionally attached to a deal.
model Task {
  id         String    @id @default(cuid())
  title      String
  dealId     String?
  deal       Deal?     @relation(fields: [dealId], references: [id])
  assigneeId String?
  assignee   User?     @relation(fields: [assigneeId], references: [id])
  dueAt      DateTime?
  status     String    @default("TODO") // TODO | DOING | DONE
  createdAt  DateTime  @default(now())
}

// A listing presentation / mandate pitch held with a prospective seller.
model Presentation {
  id        String   @id @default(cuid())
  agentId   String
  agent     User     @relation(fields: [agentId], references: [id])
  heldAt    DateTime
  outcome   String   @default("PENDING") // SIGNED | PENDING | DECLINED
  createdAt DateTime @default(now())

  @@index([heldAt])
}

// Monthly cost of supporting an agent: desk fee, training, admin, tools.
model AgentCost {
  id      String   @id @default(cuid())
  agentId String
  agent   User     @relation(fields: [agentId], references: [id])
  month   DateTime // first day of the month
  amount  Int // rand

  @@unique([agentId, month])
}

// Monthly marketing spend by channel — drives customer acquisition cost.
model MarketingSpend {
  id      String   @id @default(cuid())
  month   DateTime // first day of the month
  channel String // e.g. Property portals, Social media, Print & boards, Google Ads
  amount  Int // rand

  @@unique([month, channel])
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  body      String
  createdAt DateTime @default(now())
}
